# Model-specific parameters for relative_strength_market_aware_swing_v2.py
# Market-aware LONG model: QQQ benchmark context + stock relative strength.

MIN_BARS=320
ENABLE_SHORTS=false

BENCHMARK_SYMBOL=QQQ
REQUIRE_BENCHMARK_CONTEXT=true
BENCHMARK_SHORT_LOOKBACK_BARS=13
BENCHMARK_MID_LOOKBACK_BARS=65
BENCHMARK_LONG_LOOKBACK_BARS=260
BENCHMARK_FAST_MA_BARS=65
BENCHMARK_SLOW_MA_BARS=260
BENCHMARK_DRAWDOWN_BARS=260
MIN_BENCHMARK_MARKET_SCORE=4.8
MIN_BENCHMARK_SHORT_RETURN_PCT=-4.0
MIN_BENCHMARK_MID_RETURN_PCT=-8.0
MAX_BENCHMARK_DRAWDOWN_PCT=18.0

ALLOWED_WORLD_REGIME_LABELS=CONSTRUCTIVE,NEUTRAL
BLOCKED_WORLD_REGIME_LABELS=DEFENSIVE
REQUIRE_WORLD_REGIME_LABEL=true
BLOCKED_DAILY_POLICY_PHASES=STRESS_HIGH

ENABLE_BENCHMARK_FALLBACK=true
BENCHMARK_FALLBACK_SCORE=5.4
MIN_BENCHMARK_FALLBACK_MARKET_SCORE=5.2

MIN_LONG_COMPOSITE_SCORE=45.0
MIN_LONG_PRICE_MOMENTUM_SCORE=50.0
MIN_LONG_INTENT_SCORE=4.75

PRICE_LOOKBACK_BARS=260
TREND_LOOKBACK_BARS=260
SWING_LOOKBACK_BARS=65
CONFIRMATION_BARS=13
REBOUND_BARS=13
FAST_MA_BARS=65
SLOW_MA_BARS=260
ATR_BARS=65

MIN_TREND_RETURN_PCT=-2.0
MIN_SWING_RETURN_PCT=-3.0
MIN_CONFIRMATION_PCT=-0.25
MIN_RELATIVE_TREND_PCT=-3.0
MIN_RELATIVE_SWING_PCT=-2.0
MIN_RELATIVE_CONFIRMATION_PCT=-1.0
MIN_REBOUND_FROM_RECENT_LOW_PCT=0.4
LONG_MIN_PULLBACK_PCT=0.0
LONG_MAX_PULLBACK_PCT=12.0
LONG_IDEAL_PULLBACK_PCT=4.0
LONG_MIN_RSI=48.0
LONG_MAX_RSI=72.0
MAX_ATR_PCT=6.5
MAX_BELOW_SLOW_MA_PCT=1.5

FAILURE_FAST_ENABLED=true
FAILURE_FAST_MIN_BARS=35
FAILURE_FAST_MIN_MFE_PCT=2.0
FAILURE_FAST_MAX_RETURN_PCT=0.25
RELATIVE_FAILURE_MIN_BARS=55
