LONG_IDEAL_PULLBACK_PCT=4.0
LONG_MIN_RSI=52.0
LONG_MAX_RSI=71.0
MAX_ATR_PCT=3.0
MAX_BELOW_SLOW_MA_PCT=0.5

MIN_BREAKOUT_CONFIRMATION_PCT=5.0
