ENABLE_SHORTS=false

BENCHMARK_SYMBOL=QQQ
REQUIRE_BENCHMARK_CONTEXT=true
BENCHMARK_SHORT_LOOKBACK_BARS=13
BENCHMARK_MID_LOOKBACK_BARS=65
