# Model-specific parameters for momentum_pullback_long_v1.py
# Built from swing_alpha_forward_research slice results:
# LONG + CONSTRUCTIVE world regime + high price momentum + controlled pullback.

MIN_BARS=320
ENABLE_SHORTS=false

ALLOWED_WORLD_REGIME_LABELS=CONSTRUCTIVE
REQUIRE_WORLD_REGIME_LABEL=true

MIN_LONG_COMPOSITE_SCORE=50.0
MIN_LONG_PRICE_MOMENTUM_SCORE=75.0
MIN_LONG_MOMENTUM_SCORE=55.0
SHALLOW_PULLBACK_MIN_PRICE_MOMENTUM_SCORE=85.0

LONG_MIN_PULLBACK_PCT=5.0
LONG_MAX_PULLBACK_PCT=10.0
ALLOW_SHALLOW_PULLBACK=true
SHALLOW_MIN_PULLBACK_PCT=2.0
SHALLOW_MAX_PULLBACK_PCT=5.0

PRICE_LOOKBACK_BARS=260
TREND_LOOKBACK_BARS=260
CONFIRMATION_BARS=13
REBOUND_BARS=13
FAST_MA_BARS=65
SLOW_MA_BARS=260
ATR_BARS=65

MIN_TREND_RETURN_PCT=5.0
MIN_CONFIRMATION_PCT=-4.0
MIN_REBOUND_FROM_RECENT_LOW_PCT=0.5
LONG_MIN_RSI=35.0
LONG_MAX_RSI=72.0
MAX_ATR_PCT=8.0

USE_MISPRICING_SCORE=false
MISPRICING_WEIGHT=0.0
FUNDAMENTAL_SCORE_MODE=peer
FUNDAMENTAL_PEER_WEIGHT=1.0
FUNDAMENTAL_ABS_WEIGHT=0.0
LONG_MIN_ABSOLUTE_SCORE=
SHORT_MAX_ABSOLUTE_SCORE=
