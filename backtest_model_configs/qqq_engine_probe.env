# Model-specific parameters for qqq_engine_probe.py
#
# Purpose:
# - no stock selection alpha
# - no multi-position stacking in the model
# - QQQ only, so runner/execution/regime behaviour is easier to inspect

MIN_BARS=1
INTENT_SCORE=10.0
DIRECTION_MODE=long_only
FUNDAMENTAL_SCORE_MODE=peer
FUNDAMENTAL_PEER_WEIGHT=1.0
FUNDAMENTAL_ABS_WEIGHT=0.0
LONG_MIN_ABSOLUTE_SCORE=
SHORT_MAX_ABSOLUTE_SCORE=
PRICE_LOOKBACK_BARS=1
REJECT_NON_QQQ=true
