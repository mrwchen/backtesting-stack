# Model-specific parameters for statistical_regime_probability_v1.py

# Overrides for docker-compose defaults
LONG_TP1_PCT=0.035
LONG_TP2_PCT=0.075
SHORT_TP1_PCT=0.035
SHORT_TP2_PCT=0.075
TP1_CLOSE_RATIO=0.6

# Model-specific parameters
PROBABILITY_MIN_BARS=650
PROBABILITY_HISTORY_BARS=2200
USE_MISPRICING_SCORE=true
MISPRICING_WEIGHT=0.30
PROBABILITY_SESSION_TZ=America/New_York
EVENT_LOOKBACK_DAYS=5
VOLATILITY_LOOKBACK_DAYS=20
MIN_DAILY_OBSERVATIONS=90
MIN_CONSECUTIVE_DOWN_DAYS=2
MIN_EVENT_DROP_PCT=2.0
MIN_ANALOG_EVENTS=25
MAX_ANALOG_EVENTS=120
FULL_WEIGHT_ANALOG_EVENTS=80
PRIOR_ALPHA=1.0
PRIOR_BETA=1.0
RETURN_SIMILARITY_SCALE_PCT=2.5
VOL_SIMILARITY_SCALE_PCT=1.0
ANALOG_SAME_EVENT_DIRECTION=true
LONG_MIN_PROBABILITY=0.56
SHORT_MIN_PROBABILITY=0.56
MIN_EDGE_PCT_POINTS=2.0
EDGE_SCORE_SCALE_PCT_POINTS=12.0
LONG_STOP_VOL_MULT=1.8
SHORT_STOP_VOL_MULT=1.8
MIN_STOP_PCT=2.5
MAX_STOP_PCT=11.0
